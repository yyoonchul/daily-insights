---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getDailyInsightEntriesSorted } from '../lib/dailyInsights';

const dailyInsights = await getDailyInsightEntriesSorted();
---

<BaseLayout title="Daily Insights - Yoonchul Yi">
  <section class="page">
    <h1>Daily Insights</h1>
    <ul class="insight-list">
      {dailyInsights.map(({ meta }) => (
        <li><a href={meta.href}>{meta.isoDate}</a></li>
      ))}
    </ul>
  </section>
</BaseLayout>
